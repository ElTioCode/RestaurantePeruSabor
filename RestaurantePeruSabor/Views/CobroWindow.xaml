<Window x:Class="RestaurantePeruSabor.Views.CobroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobro y Comprobante"
        Height="580" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1a1a2e">

    <Grid Margin="30">
        <StackPanel>

            <TextBlock Text="COBRO Y COMPROBANTE"
                       FontSize="15" FontWeight="Bold"
                       Foreground="#f38ba8"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Border Background="#313244" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock x:Name="lblCliente"  Foreground="#a6adc8" FontSize="11" Margin="0,0,0,3"/>
                    <TextBlock x:Name="lblMesa"     Foreground="#a6adc8" FontSize="11" Margin="0,0,0,3"/>
                    <TextBlock x:Name="lblSubtotal" Foreground="#cdd6f4" FontSize="12" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- DESCUENTO -->
            <TextBlock Text="Descuento (%)" Foreground="#a6adc8" FontSize="11" Margin="0,0,0,4"/>
            <TextBox x:Name="txtDescuento" Text="0"
                     Height="36" FontSize="12" Padding="8,6"
                     Background="#313244" Foreground="#cdd6f4"
                     BorderBrush="#45475a" BorderThickness="1"
                     CaretBrush="#cdd6f4" Margin="0,0,0,14"/>

            <!-- TIPO COMPROBANTE -->
            <TextBlock Text="Tipo de comprobante" Foreground="#a6adc8" FontSize="11" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbComprobante" Height="36" FontSize="12"
                      BorderBrush="#45475a" Margin="0,0,0,14"
                      SelectionChanged="CmbComprobante_SelectionChanged">
                <ComboBoxItem Content="Boleta Electronica" IsSelected="True"/>
                <ComboBoxItem Content="Factura Electronica"/>
            </ComboBox>

            <!-- DATOS FACTURA (solo visible si es Factura) -->
            <StackPanel x:Name="panelFactura" Visibility="Collapsed" Margin="0,0,0,14">
                <TextBlock Text="RUC Empresa" Foreground="#a6adc8" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="txtRuc" Height="34" FontSize="12" Padding="8,6"
                         Background="#313244" Foreground="#cdd6f4"
                         BorderBrush="#45475a" BorderThickness="1"
                         CaretBrush="#cdd6f4" Margin="0,0,0,8"/>
                <TextBlock Text="Razon Social" Foreground="#a6adc8" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="txtRazonSocial" Height="34" FontSize="12" Padding="8,6"
                         Background="#313244" Foreground="#cdd6f4"
                         BorderBrush="#45475a" BorderThickness="1"
                         CaretBrush="#cdd6f4"/>
            </StackPanel>

            <!-- TOTAL -->
            <Border Background="#2a1e1e" CornerRadius="6" Padding="12,8" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL A PAGAR:  " Foreground="#a6adc8" FontSize="13"/>
                    <TextBlock x:Name="lblTotal" Text="S/ 0.00"
                               Foreground="#f38ba8" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- BOTÓN COBRAR -->
            <Button Content="Confirmar Cobro y Generar PDF"
                    Height="44" FontSize="13" FontWeight="Bold"
                    Cursor="Hand"
                    Background="#f38ba8"
                    Foreground="#1a1a2e"
                    BorderThickness="0"
                    Click="BtnConfirmar_Click"/>

        </StackPanel>
    </Grid>
</Window>
