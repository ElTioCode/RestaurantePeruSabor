<Window x:Class="RestaurantePeruSabor.Views.PedidoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toma de Pedido"
        Height="580" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1a1a2e">

    <Window.Resources>
        <Style x:Key="BtnPlato" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Background" Value="#2e2a1e"/>
            <Setter Property="BorderBrush" Value="#f9e2af"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="BtnBebida" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Background" Value="#1e2a2e"/>
            <Setter Property="BorderBrush" Value="#89dceb"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO: MENU -->
        <StackPanel Grid.Column="0">

            <TextBlock Text="MENU" FontSize="14" FontWeight="Bold"
                       Foreground="#f9e2af" Margin="0,0,0,15"/>

            <Border Background="#313244" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock x:Name="lblCliente" Text="Cliente: " Foreground="#a6adc8" FontSize="11"/>
                    <TextBlock x:Name="lblMesa"    Text="Mesa: "    Foreground="#a6adc8" FontSize="11"/>
                </StackPanel>
            </Border>

            <TextBlock Text="PLATOS" Foreground="#6c7086" FontSize="10" Margin="0,0,0,6"/>
            <Button Content="Lomo Saltado - S/ 35.00"
                    Tag="Lomo Saltado|35"
                    Style="{StaticResource BtnPlato}"
                    Click="BtnAgregarItem_Click"/>
            <Button Content="Ceviche - S/ 40.00"
                    Tag="Ceviche|40"
                    Style="{StaticResource BtnPlato}"
                    Click="BtnAgregarItem_Click"/>
            <Button Content="Arroz con Leche - S/ 8.00"
                    Tag="Arroz con Leche|8"
                    Style="{StaticResource BtnPlato}"
                    Margin="0,0,0,12"
                    Click="BtnAgregarItem_Click"/>

            <TextBlock Text="BEBIDAS" Foreground="#6c7086" FontSize="10" Margin="0,0,0,6"/>
            <Button Content="Gaseosa 500ml - S/ 5.00"
                    Tag="Gaseosa 500ml|5"
                    Style="{StaticResource BtnBebida}"
                    Click="BtnAgregarItem_Click"/>
            <Button Content="Cerveza 620ml - S/ 10.00"
                    Tag="Cerveza 620ml|10"
                    Style="{StaticResource BtnBebida}"
                    Click="BtnAgregarItem_Click"/>
            <Button Content="Agua Mineral - S/ 3.00"
                    Tag="Agua Mineral|3"
                    Style="{StaticResource BtnBebida}"
                    Click="BtnAgregarItem_Click"/>

        </StackPanel>

        <!-- PANEL DERECHO: PEDIDO -->
        <StackPanel Grid.Column="2">

            <TextBlock Text="PEDIDO ACTUAL" FontSize="14" FontWeight="Bold"
                       Foreground="#cba6f7" Margin="0,0,0,15"/>

            <DataGrid x:Name="dgPedido"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Height="300"
                      Background="#181825"
                      RowBackground="#1e1e2e"
                      AlternatingRowBackground="#252540"
                      Foreground="#cdd6f4"
                      BorderBrush="#45475a"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#313244"
                      Margin="0,0,0,12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item"     Binding="{Binding Nombre}"   Width="*"/>
                    <DataGridTextColumn Header="Cant."    Binding="{Binding Cantidad}" Width="50"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="TOTAL:  " Foreground="#a6adc8" FontSize="13"/>
                    <TextBlock x:Name="lblTotal" Text="S/ 0.00"
                               Foreground="#a6e3a1" FontSize="15" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Button Content="Cobrar"
                    Height="44"
                    FontSize="13"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Background="#a6e3a1"
                    Foreground="#1a1a2e"
                    Click="BtnCobrar_Click"/>

        </StackPanel>
    </Grid>
</Window>
